{
    "name": "Algo Contest",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-python.python",
                "charliermarsh.ruff",
                "astral-sh.ty"
            ],
            "settings": {
                "files.exclude": {
                    ".gitignore": true,
                    ".clangd": true,
                    ".clang-format": true,
                    ".devcontainer": true,
                    ".vscode": true,
                    "README.md": true
                }
            }
        }
    }
}